{{!
    @template mod_readaloud/quizcontainer

    Quiz container

    Example context (json):
    {
    }
}}
<section id="mod_readaloud_quizmode" class="quiz-mode" role="region" aria-labelledby="quiz-title">
    <h2 id="quiz-title" class="visually-hidden">{{#str}}mode_quiz, mod_readaloud{{/str}}</h2>

    {{< mod_readaloud/activity_header_inpage}}
          {{$instructions}}{{#str}} quizhelp, mod_readaloud {{/str}}{{/instructions}}
    {{/ mod_readaloud/activity_header_inpage}}

    <div id="{{M_QUIZ_CONTAINER_WRAP}}" class="{{M_QUIZ_CONTAINER_WRAP}}">
        <div id="{{M_QUIZ_CONTAINER}}" class="{{M_QUIZ_CONTAINER}} d-flex flex-column">
            <div id="quizquestion" class="quizquestion">
                {{{quizhtml}}}
            </div>
            <!--A big spinner in the centre of the page-->
            <div id="mod_readaloud_quizspinner" class="mod_readaloud_quizspinner d-none justify-content-center my-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">{{#str}}loading, core{{/str}}</span>
                </div>
            </div>
            {{#readreport.thepassage}}
                {{>mod_readaloud/studentreadingpassage}}
            {{/readreport.thepassage}}
        </div>
    </div>
</section>
