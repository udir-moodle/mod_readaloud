{{! We have a result !! }}
{{#ready }}
    <div class="col-4">
        <div class="mod_readaloud_readreport_card h-100 d-flex flex-column flex-md-row justify-content-between align-items-center text-center text-md-start p-3 p-md-5 rounded border">
            <div class="statbox-item order-1 order-md-0">
                <div class="stat-label text-uppercase small fw-semibold mb-2">
                    {{#str}}wpm, mod_readaloud{{/str}}
                </div>
                <div class="fw-bold fs-1">{{wpm}}</div>
            </div>
            <span class="statbox-icon order-0 order-md-1 mb-2 mb-md-0">
                {{#pix}} bolt, mod_readaloud {{/pix}}
            </span>
        </div>
    </div>

    {{! Total words goal }}
    <div class="col-4">
        <div class="mod_readaloud_readreport_card h-100 d-flex flex-column flex-md-row justify-content-between align-items-center text-center text-md-start p-3 p-md-5 rounded border">
            <div class="statbox-item order-1 order-md-0">
                <div class="stat-label text-uppercase small fw-semibold mb-2">
                    {{#str}}accuracy, mod_readaloud{{/str}}
                </div>
                <div class="fw-bold fs-1">{{acc}}{{#str}}unit_percent, mod_readaloud{{/str}}</div>
            </div>
            <span class="statbox-icon order-0 order-md-1 mb-2 mb-md-0">
                {{#pix}} percent, mod_readaloud {{/pix}}
            </span>
        </div>
    </div>

    {{! Total words goal }}
    <div class="col-4">
        <div class="mod_readaloud_readreport_card h-100 d-flex flex-column flex-md-row justify-content-between align-items-center text-center text-md-start p-3 p-md-5 rounded border">
            <div class="statbox-item order-1 order-md-0">
                <div class="stat-label text-uppercase small fw-semibold mb-2">
                    {{#str}}totalwords, mod_readaloud{{/str}}
                </div>
                <div class="fw-bold fs-1">{{totalwords}}</div>
            </div>
            <span class="statbox-icon order-0 order-md-1 mb-2 mb-md-0">
                {{#pix}} checkcircle, mod_readaloud {{/pix}}
            </span>
        </div>
    </div>
{{/ready}}
